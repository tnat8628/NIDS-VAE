# ============================================================
# NIDS VAE – Environment Configuration Template
# ============================================================
# Sao chép file này thành .env và chỉnh sửa giá trị phù hợp.
#
#   copy .env.example .env
#
# Lưu ý: Không commit file .env lên Git.
# ============================================================

# --- Backend ---

# Host và port của FastAPI backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Đường dẫn thư mục artifacts (tương đối từ gốc dự án)
ARTIFACTS_DIR=artifacts

# Kích thước batch cho inference (giảm nếu RAM không đủ)
INFERENCE_BATCH_SIZE=4096

# --- Frontend ---

# URL của backend (dùng trong React để gọi API)
# Thay đổi nếu backend chạy ở host/port khác
VITE_API_BASE_URL=http://127.0.0.1:8000

# --- Logging ---

# Cấp độ log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
